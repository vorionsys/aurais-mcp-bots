{
  "name": "@vorionsys/aurais-mcp-market-scout",
  "version": "0.3.0",
  "description": "Aurais Market Scout as an MCP server — tickers in, per-ticker briefings out (RSI, MACD, SMA, volume, relative strength vs SPY) with a signed Vorion proof chain (via @vorionsys/aurais-core).",
  "keywords": [
    "mcp",
    "aurais",
    "vorion",
    "markets",
    "stocks",
    "crypto",
    "indicators"
  ],
  "license": "Apache-2.0",
  "author": "Vorion LLC <team@vorion.org>",
  "homepage": "https://github.com/voriongit/aurais-mcp-bots/tree/main/packages/market-scout",
  "repository": {
    "type": "git",
    "url": "https://github.com/voriongit/aurais-mcp-bots.git",
    "directory": "packages/market-scout"
  },
  "bugs": {
    "url": "https://github.com/voriongit/aurais-mcp-bots/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aurais-mcp-market-scout": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "prepack": "node -e \"require('node:fs').copyFileSync('../../LICENSE','LICENSE')\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
