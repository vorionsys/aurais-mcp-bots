{
  "name": "@vorionsys/aurais-verify",
  "version": "0.3.1",
  "description": "Offline verifier for Aurais proof chains — checks every event's ed25519 signature, hash links, sequence, and key consistency. No network, no API key. The companion to the signed chains emitted by every @vorionsys/aurais-mcp-* bot.",
  "keywords": [
    "aurais",
    "vorion",
    "proof-chain",
    "verify",
    "ed25519",
    "provenance"
  ],
  "license": "Apache-2.0",
  "author": "Vorion LLC <team@vorion.org>",
  "homepage": "https://github.com/voriongit/aurais-mcp-bots/tree/main/packages/proof-verifier",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voriongit/aurais-mcp-bots.git",
    "directory": "packages/proof-verifier"
  },
  "bugs": {
    "url": "https://github.com/voriongit/aurais-mcp-bots/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aurais-verify": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "prepack": "node -e \"require('node:fs').copyFileSync('../../LICENSE','LICENSE')\""
  },
  "dependencies": {
    "@vorionsys/aurais-core": "^0.1.0"
  },
  "devDependencies": {
    "tsx": "^4.20.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
