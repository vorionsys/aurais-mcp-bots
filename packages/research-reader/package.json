{
  "name": "@vorionsys/aurais-mcp-research-reader",
  "version": "0.3.1",
  "description": "Aurais Research Reader as an MCP server — paste a paper or article, get a structured read with verbatim-verified quotes + a signed Vorion proof chain (via @vorionsys/aurais-core).",
  "keywords": [
    "mcp",
    "aurais",
    "vorion",
    "research",
    "reading",
    "proof-chain"
  ],
  "license": "Apache-2.0",
  "author": "Vorion LLC <team@vorion.org>",
  "homepage": "https://github.com/voriongit/aurais-mcp-bots/tree/main/packages/research-reader",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voriongit/aurais-mcp-bots.git",
    "directory": "packages/research-reader"
  },
  "bugs": {
    "url": "https://github.com/voriongit/aurais-mcp-bots/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aurais-mcp-research-reader": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "prepack": "node -e \"require('node:fs').copyFileSync('../../LICENSE','LICENSE')\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@vorionsys/aurais-core": "^0.1.0",
    "zod": "^3.24.1",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "tsx": "^4.20.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
